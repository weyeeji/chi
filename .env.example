PORT=8787
CLIENT_ORIGIN=http://localhost:5173
ADMIN_TOKEN=change-this-admin-token

# Agent API. Keep the real key only in .env.
AGENT_API_BASE_URL=https://aiping.cn/api/v1
AGENT_API_KEY=replace-with-your-key
AGENT_MODEL=DeepSeek-V4-Flash
AGENT_MODE=live
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=360

# Frontend can leave this blank in production when Express serves the built app.
VITE_API_BASE_URL=http://localhost:8787
